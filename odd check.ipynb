   "source": [
    "def check_number(n):\n",
    "    if n % 2 == 0:\n",
    "        return \"Even\"\n",
    "    else:\n",
    "        return \"Odd\"\n",
    "\n",
    "# Ab isay check karein\n",
    "result = check_number(7)\n",
    "print(f\"Number 7 is: {result}\")"
   ]
